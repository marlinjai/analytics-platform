{
  "name": "analytics-platform",
  "version": "0.6.0",
  "private": true,
  "description": "Self-hosted analytics, heatmap, and session replay platform",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "infisical run --token=$INFISICAL_LUMITRA_TOKEN --env=dev --projectId=$INFISICAL_PID_ANALYTICS -- pnpm --filter @analytics-platform/dashboard dev",
    "dev:local": "pnpm --filter @analytics-platform/dashboard dev",
    "dev:demo": "pnpm --filter @analytics-platform/dashboard dev & pnpm --filter @analytics-platform/demo dev & wait",
    "lint": "pnpm -r lint",
    "test": "vitest",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@marlinjai/clearify": "^1.13.0",
    "@playwright/test": "^1.59.1",
    "dotenv": "^17.3.1",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "@marlinjai/auth-brain-shared": "file:../lumitra-infra/auth-brain/packages/shared"
    }
  }
}
