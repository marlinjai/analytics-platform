{
  "name": "@marlinjai/analytics-core",
  "version": "1.0.0",
  "description": "Runtime-agnostic deterministic experiment assignment and feature-flag evaluation for Lumitra Analytics",
  "type": "module",
  "exports": {
    ".": {
