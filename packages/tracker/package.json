{
  "name": "@marlinjai/analytics-tracker",
  "version": "0.1.2",
  "description": "Lightweight browser analytics tracker — pageviews, clicks, heatmaps, session replay",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "bundle-check": "bash ../../scripts/check-bundle-size.sh"
  },
  "dependencies": {},
  "peerDependencies": {
    "rrweb": "^2.0.0-alpha.0"
  },
  "peerDependenciesMeta": {
    "rrweb": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  },
  "sideEffects": false,
  "license": "MIT"
}
