{
  "manifest_version": 3,
  "name": "Lumitra Analytics",
  "version": "0.2.0",
  "description": "Heatmap overlay & analytics for Lumitra Analytics",
  "permissions": ["activeTab", "storage", "alarms", "scripting", "sidePanel"],
  "host_permissions": ["https://analytics.lumitra.co/*", "<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": ["heatmap.min.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
