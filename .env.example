# Database (Postgres)
DATABASE_URL=postgres://analytics:analytics_dev@localhost:5432/analytics

# ClickHouse
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=clickhouse_dev

# NextAuth v5
# AUTH_SECRET is the v5 name for NEXTAUTH_SECRET (old name still works as fallback)
AUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
# AUTH_URL is optional in v5 — host is inferred from request headers in most deployments
# AUTH_URL=http://localhost:3100

# GitHub OAuth (optional, for login)
# v5 convention: AUTH_[PROVIDER]_ID / AUTH_[PROVIDER]_SECRET — auto-discovered, no code config needed
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Seed user — created automatically on `pnpm dev`
SEED_USER_EMAIL=admin@localhost
SEED_USER_PASSWORD=admin123
